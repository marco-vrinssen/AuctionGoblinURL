name: Build and Upload Addon

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout repository
      uses: actions/checkout@v2

    - name: Set up Node.js
      uses: actions/setup-node@v2
      with:
        node-version: '14'

    - name: Install dependencies
      run: npm install

    - name: Build addon
      run: npm run build

    - name: Package addon files
      run: zip -r AuctionGoblinURL.zip AuctionGoblinURL.lua AuctionGoblinURL.toc

    - name: Upload to CurseForge
      uses: itsmeow/curseforge-upload@v1
      with:
        api-token: ${{ secrets.CURSEFORGE_API_TOKEN }}
        project-id: 1071589
        file: AuctionGoblinURL.zip
        package-as: AuctionGoblinURL.zip
